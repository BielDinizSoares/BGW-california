---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import ContactForm from "../components/Contact/ContactForm.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Contact Us — BGW California">
  <Navbar />

  <!-- ═══════════════════════════════════════════
       HERO BANNER
       ═══════════════════════════════════════════ -->
  <section
    class="relative bg-zinc-950 pt-[120px] sm:pt-[140px] pb-16 sm:pb-24 overflow-hidden"
  >
    <div
      class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_30%,rgba(37,99,235,0.05),transparent)]"
    >
    </div>
    <div
      class="relative z-10 w-full max-w-[1600px] mx-auto px-5 sm:px-8 lg:px-10"
    >
      <p class="text-blue-500 text-xs font-bold uppercase tracking-[4px] mb-4">
        Get in Touch
      </p>
      <h1
        class="text-white text-3xl sm:text-5xl lg:text-7xl font-bold uppercase tracking-tight leading-none mb-4 sm:mb-6"
      >
        Contact Us
      </h1>
      <p class="text-zinc-500 text-sm max-w-lg leading-relaxed">
        Ready to transform your vehicle? Reach out to our team for a free
        consultation and quote. We respond within 24 hours.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FORM + IMAGE SECTION
       ═══════════════════════════════════════════ -->
  <section id="form" class="bg-black">
    <div class="flex flex-col lg:flex-row min-h-screen">
      <!-- Left: Image -->
      <div
        class="lg:w-[55%] relative overflow-hidden min-h-[40vh] lg:min-h-screen"
      >
        <img
          src="/imagem-form.webp"
          alt="Car detailing service"
          class="absolute inset-0 w-full h-full object-cover"
        />
        <div
          class="absolute inset-0 bg-gradient-to-r from-black/10 via-transparent to-black/60"
        >
        </div>
        <div class="absolute bottom-10 left-10 right-10 hidden lg:block">
          <p class="text-white/40 text-xs uppercase tracking-[3px]">
            BGW California
          </p>
          <p class="text-white text-lg font-bold uppercase tracking-wide mt-1">
            Precision. Quality. Detail.
          </p>
        </div>
      </div>

      <!-- Right: Form -->
      <div
        class="lg:w-[45%] flex items-center justify-center px-5 sm:px-8 py-12 sm:py-20 lg:py-0 bg-black"
      >
        <ContactForm />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       INFO CARDS
       ═══════════════════════════════════════════ -->
  <section class="bg-black">
    <div class="w-full max-w-[1600px] mx-auto px-5 sm:px-8 lg:px-10">
      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-px bg-zinc-800"
      >
        <!-- Phone -->
        <div class="bg-zinc-950 p-5 sm:p-8 flex flex-col items-start">
          <svg
            class="w-8 h-8 text-blue-500 mb-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
            ></path>
          </svg>
          <h3
            class="text-white text-sm font-bold uppercase tracking-[1px] mb-2"
          >
            Phone
          </h3>
          <p class="text-zinc-400 text-sm"><a href="tel:+13100000000" class="text-zinc-400 no-underline hover:text-white transition-colors">+1 (310) 000-0000</a></p>
        </div>

        <!-- Email -->
        <div class="bg-zinc-950 p-5 sm:p-8 flex flex-col items-start">
          <svg
            class="w-8 h-8 text-blue-500 mb-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
            ></path>
          </svg>
          <h3
            class="text-white text-sm font-bold uppercase tracking-[1px] mb-2"
          >
            Email
          </h3>
          <p class="text-zinc-400 text-sm"><a href="mailto:contact@bgwcalifornia.com" class="text-zinc-400 no-underline hover:text-white transition-colors">contact@bgwcalifornia.com</a></p>
        </div>

        <!-- Address -->
        <div class="bg-zinc-950 p-5 sm:p-8 flex flex-col items-start">
          <svg
            class="w-8 h-8 text-blue-500 mb-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
            ></path>
          </svg>
          <h3
            class="text-white text-sm font-bold uppercase tracking-[1px] mb-2"
          >
            Address
          </h3>
          <p class="text-zinc-400 text-sm"><a href="https://maps.google.com/?q=Los+Angeles+CA" target="_blank" rel="noopener noreferrer" class="text-zinc-400 no-underline hover:text-white transition-colors">Los Angeles, CA</a></p>
        </div>

        <!-- Hours -->
        <div class="bg-zinc-950 p-5 sm:p-8 flex flex-col items-start">
          <svg
            class="w-8 h-8 text-blue-500 mb-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"></path>
          </svg>
          <h3
            class="text-white text-sm font-bold uppercase tracking-[1px] mb-2"
          >
            Hours
          </h3>
          <p class="text-zinc-400 text-sm">Mon – Sat, 8 AM – 6 PM</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SERVICES QUICK-NAV — inspired by image-4 CTA boxes
       ═══════════════════════════════════════════ -->
  <section class="bg-zinc-950 py-12 sm:py-16 lg:py-20">
    <div class="w-full max-w-[1600px] mx-auto px-5 sm:px-8 lg:px-10">
      <div class="border-l-4 border-blue-500 pl-4 sm:pl-6 mb-10 sm:mb-14">
        <p
          class="text-zinc-500 text-[10px] sm:text-xs uppercase tracking-[3px] mb-2"
        >
          Explore
        </p>
        <h2
          class="text-white text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold leading-tight"
        >
          Not sure which service you need?
        </h2>
      </div>

      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-px bg-zinc-800"
      >
        <a
          href="/services/plasti-dip"
          class="group bg-black hover:bg-zinc-900 transition-colors duration-300 p-8 no-underline"
        >
          <span class="text-zinc-500 text-3xl font-bold block mb-3">01</span>
          <h3
            class="text-white text-sm font-bold uppercase tracking-[1px] mb-2"
          >
            Plasti Dip
          </h3>
          <p class="text-zinc-500 text-xs leading-relaxed mb-4">
            Removable rubber coating for temporary color changes.
          </p>
          <span
            class="text-blue-500 text-xs font-bold uppercase tracking-[2px] group-hover:border-b group-hover:border-blue-500 pb-0.5 transition-all"
            >Learn More →</span
          >
        </a>
        <a
          href="/services/paint-protection"
          class="group bg-black hover:bg-zinc-900 transition-colors duration-300 p-8 no-underline"
        >
          <span class="text-zinc-500 text-3xl font-bold block mb-3">02</span>
          <h3
            class="text-white text-sm font-bold uppercase tracking-[1px] mb-2"
          >
            Paint Protection
          </h3>
          <p class="text-zinc-500 text-xs leading-relaxed mb-4">
            Self-healing film that shields against road hazards.
          </p>
          <span
            class="text-blue-500 text-xs font-bold uppercase tracking-[2px] group-hover:border-b group-hover:border-blue-500 pb-0.5 transition-all"
            >Learn More →</span
          >
        </a>
        <a
          href="/services/vinyl-wrap"
          class="group bg-black hover:bg-zinc-900 transition-colors duration-300 p-8 no-underline"
        >
          <span class="text-zinc-500 text-3xl font-bold block mb-3">03</span>
          <h3
            class="text-white text-sm font-bold uppercase tracking-[1px] mb-2"
          >
            Vinyl Wrap
          </h3>
          <p class="text-zinc-500 text-xs leading-relaxed mb-4">
            Full-body color change in any finish imaginable.
          </p>
          <span
            class="text-blue-500 text-xs font-bold uppercase tracking-[2px] group-hover:border-b group-hover:border-blue-500 pb-0.5 transition-all"
            >Learn More →</span
          >
        </a>
        <a
          href="/services/window-tint"
          class="group bg-black hover:bg-zinc-900 transition-colors duration-300 p-8 no-underline"
        >
          <span class="text-zinc-500 text-3xl font-bold block mb-3">04</span>
          <h3
            class="text-white text-sm font-bold uppercase tracking-[1px] mb-2"
          >
            Window Tint
          </h3>
          <p class="text-zinc-500 text-xs leading-relaxed mb-4">
            Ceramic films for heat rejection and UV protection.
          </p>
          <span
            class="text-blue-500 text-xs font-bold uppercase tracking-[2px] group-hover:border-b group-hover:border-blue-500 pb-0.5 transition-all"
            >Learn More →</span
          >
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
