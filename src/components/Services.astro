---
import { Image } from 'astro:assets';
import plastiDipImg from "../assets/services/plasti-dip.png";
import paintProtectionImg from "../assets/services/paint-protection.png";
import vinylWrapImg from "../assets/services/vinyl-wrap.png";
import windowTintImg from "../assets/services/window-tint.png";

const services = [
  {
    id: "plasti-dip",
    slug: "plasti-dip",
    title: "Plasti Dip",
    tagline: "Removable & Versatile",
    description:
      "A flexible, rubber-based coating that can be applied to virtually any surface. Perfect for temporary color changes, wheel coating, or protecting trim.",
    image: plastiDipImg,
  },
  {
    id: "paint-protection",
    slug: "paint-protection",
    title: "Paint Protection Film",
    tagline: "Invisible Armor",
    description:
      "Military-grade urethane film that shields your paint from rock chips, road debris, UV rays, and minor abrasions. Virtually invisible and self-healing.",
    image: paintProtectionImg,
  },
  {
    id: "vinyl-wrap",
    slug: "vinyl-wrap",
    title: "Vinyl Wrap",
    tagline: "Total Transformation",
    description:
      "Full-body or partial vinyl wraps in matte, gloss, satin, chrome, and textured finishes. Change the entire look of your vehicle without affecting resale value.",
    image: vinylWrapImg,
  },
  {
    id: "window-tint",
    slug: "window-tint",
    title: "Window Tint",
    tagline: "Privacy & Performance",
    description:
      "Premium ceramic and carbon window films that block up to 99% of UV rays, reduce interior heat, and enhance privacy. California compliant.",
    image: windowTintImg,
  },
];
---

<section id="services" class="bg-black py-28">
  <div class="w-full max-w-[1600px] mx-auto px-10">

    <!-- Section Header -->
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6 mb-20">
      <div>
        <p class="text-blue-500 text-xs font-bold uppercase tracking-[4px] mb-4">What We Offer</p>
        <h2 class="text-white text-5xl lg:text-6xl font-bold uppercase leading-tight tracking-tight">
          Our Services
        </h2>
      </div>
      <p class="text-zinc-500 text-sm max-w-xs leading-relaxed lg:text-right">
        Each service is performed by certified technicians using premium materials from industry-leading brands.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
      {services.map((service) => (
        <a
          href={`/services/${service.slug}`}
          id={service.id}
          class="group relative flex flex-col bg-zinc-950 border border-zinc-800/60
                 overflow-hidden no-underline
                 hover:border-blue-600/40 hover:shadow-[0_0_40px_rgba(37,99,235,0.08)]
                 transition-all duration-500"
        >
          <!-- Image Container -->
          <div class="relative w-full aspect-[4/3] overflow-hidden">
            <Image
              src={service.image}
              alt={service.title}
              width={480}
              format="webp"
              quality={80}
              loading="lazy"
              class="w-full h-full object-cover
                     scale-110 group-hover:scale-[1.15]
                     transition-transform duration-700 ease-out"
            />
            <!-- Gradient overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/20 to-transparent"></div>

            <!-- Tagline badge -->
            <span class="absolute top-4 left-4 text-blue-400 text-[10px] font-bold uppercase tracking-[2px]
                         bg-black/60 backdrop-blur-sm border border-blue-600/20 px-3 py-1.5">
              {service.tagline}
            </span>
          </div>

          <!-- Content -->
          <div class="flex flex-col flex-1 p-6 pt-5">
            <h3 class="text-white text-xl font-bold uppercase tracking-wide mb-3
                       group-hover:text-blue-400 transition-colors duration-300">
              {service.title}
            </h3>

            <p class="text-zinc-400 text-sm leading-relaxed mb-6 flex-1">
              {service.description}
            </p>

            <!-- Learn More -->
            <span class="inline-flex items-center gap-2 text-white text-xs font-bold uppercase tracking-[2px]
                         group-hover:text-blue-400 group-hover:gap-3
                         transition-all duration-300">
              Learn More
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>
