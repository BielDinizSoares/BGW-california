---
import logo from "../assets/BGW-logo.webp";

const services = [
  { title: "Plasti Dip", href: "/services/plasti-dip" },
  { title: "Paint Protection Film", href: "/services/paint-protection" },
  { title: "Vinyl Wrap", href: "/services/vinyl-wrap" },
  { title: "Window Tint", href: "/services/window-tint" },
];

const company = [
  { title: "Home", href: "/" },
  { title: "Portfolio", href: "/portfolio" },
  { title: "Contact", href: "/contact" },
];
---

<footer class="bg-zinc-950 border-t border-white/5">

  <!-- Map strip -->
  <div class="w-full h-[300px] relative">
    <iframe
      title="BGW California Location"
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d423286.27405770525!2d-118.69192047471653!3d34.02016130653294!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80c2c75ddc27da13%3A0xe22fdf6f254608f4!2sLos%20Angeles%2C%20CA!5e0!3m2!1sen!2sus!4v1709000000000"
      class="absolute inset-0 w-full h-full border-0 grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-500"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
  </div>

  <!-- Back to top -->
  <div class="flex justify-center py-6 border-b border-white/5">
    <a href="#" class="text-zinc-500 text-xs uppercase tracking-[2px] no-underline hover:text-white transition-colors duration-300 flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
      </svg>
      Back to top
    </a>
  </div>

  <!-- Footer content -->
  <div class="w-full max-w-[1600px] mx-auto px-10 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">

      <!-- Column 1: Brand -->
      <div>
        <a href="/" class="flex items-center gap-3 no-underline mb-6">
          <img src={logo.src} alt="BGW California" width="48" height="48" class="h-12 w-auto" />
          <div class="flex flex-col">
            <span class="text-white text-xl font-bold leading-none tracking-wide">BGW</span>
            <span class="text-zinc-500 text-[11px] tracking-[2px] uppercase">California</span>
          </div>
        </a>
        <p class="text-zinc-500 text-sm leading-relaxed">
          Premium automotive wrapping, paint protection, and window tinting. Serving California with precision and quality.
        </p>
      </div>

      <!-- Column 2: Services -->
      <div>
        <h3 class="text-white text-sm font-bold uppercase tracking-[2px] mb-6">Services</h3>
        <ul class="flex flex-col gap-3 list-none m-0 p-0">
          {services.map((item) => (
            <li>
              <a href={item.href} class="text-zinc-500 text-sm no-underline hover:text-white transition-colors duration-300">
                {item.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Company -->
      <div>
        <h3 class="text-white text-sm font-bold uppercase tracking-[2px] mb-6">Company</h3>
        <ul class="flex flex-col gap-3 list-none m-0 p-0">
          {company.map((item) => (
            <li>
              <a href={item.href} class="text-zinc-500 text-sm no-underline hover:text-white transition-colors duration-300">
                {item.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 4: Contact info -->
      <div>
        <h3 class="text-white text-sm font-bold uppercase tracking-[2px] mb-6">Contact</h3>
        <ul class="flex flex-col gap-4 list-none m-0 p-0">
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-blue-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
            <span class="text-zinc-500 text-sm">Los Angeles, CA</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-blue-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
            </svg>
            <span class="text-zinc-500 text-sm">+1 (310) 000-0000</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-blue-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
            <span class="text-zinc-500 text-sm">contact@bgwcalifornia.com</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-blue-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
            <span class="text-zinc-500 text-sm">Mon – Sat, 8 AM – 6 PM</span>
          </li>
        </ul>

        <!-- Social icons -->
        <div class="flex gap-4 mt-6">
          <a href="#" class="text-zinc-600 hover:text-white transition-colors duration-300" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <a href="#" class="text-zinc-600 hover:text-white transition-colors duration-300" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="#" class="text-zinc-600 hover:text-white transition-colors duration-300" aria-label="YouTube">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </div>
      </div>

    </div>
  </div>

  <!-- Copyright bar -->
  <div class="border-t border-white/5">
    <div class="w-full max-w-[1600px] mx-auto px-10 py-5 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-zinc-600 text-xs">&copy; 2026 BGW California. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="#" class="text-zinc-600 text-xs no-underline hover:text-zinc-400 transition-colors">Privacy Policy</a>
        <a href="#" class="text-zinc-600 text-xs no-underline hover:text-zinc-400 transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>

</footer>
