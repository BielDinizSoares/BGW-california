---
import Layout from '../layouts/Layout.astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';

interface Highlight {
  title: string;
  description: string;
  image?: ImageMetadata;
}

interface Spec {
  label: string;
  value: string;
  icon?: string;
}

interface SiblingService {
  title: string;
  slug: string;
  tagline: string;
  image?: ImageMetadata;
}

interface Props {
  name: string;
  slug: string;
  tagline: string;
  headline: string;
  description: string;
  heroImage?: ImageMetadata;
  showcaseImage?: ImageMetadata;
  highlights: Highlight[];
  specs: Spec[];
  siblings: SiblingService[];
}

const { name, slug, tagline, headline, description, heroImage, showcaseImage, highlights, specs, siblings } = Astro.props;

// Map of icon names to SVG paths (Heroicons outline 24x24)
const iconMap: Record<string, string> = {
  clock: 'M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z',
  shield: 'M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z',
  fire: 'M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z M12 18a3.75 3.75 0 0 0 .495-7.468 5.99 5.99 0 0 0-1.925 3.547 5.975 5.975 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z',
  sparkles: 'M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z',
  bolt: 'm3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z',
  eye: 'M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z',
  paintbrush: 'M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42',
  check: 'M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z',
  cube: 'm21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25',
  sun: 'M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z',
  wrench: 'M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085',
  tag: 'M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z M6 6h.008v.008H6V6Z',
  droplet: 'M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418',
  beaker: 'M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5',
};

// Brief summary for hero (first 180 chars)
const briefSummary = description.length > 180 ? description.substring(0, 180).trim() + '…' : description;
---

<Layout title={`${name} — BGW California`}>
  <Navbar />

  <!-- ═══════════════════════════════════════════════════
       SECTION 1 · HERO — full-screen background image with CTAs
       ═══════════════════════════════════════════════════ -->
  <section class="relative min-h-screen flex flex-col items-center justify-center bg-zinc-950 overflow-hidden pt-[80px] sm:pt-[100px]">

    <!-- Full-width hero image as background -->
    {heroImage ? (
      <div class="absolute inset-0">
        <img
          src={heroImage.src}
          alt={`${name} — BGW California`}
          class="w-full h-full object-cover scale-110 opacity-60"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/30 to-zinc-950/50"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-zinc-950/70 via-transparent to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-zinc-950/40 via-transparent to-zinc-950/40"></div>
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_50%_at_50%_45%,transparent,rgba(9,9,11,0.5))]"></div>
      </div>
    ) : (
      <div class="absolute inset-0 bg-gradient-to-b from-zinc-900 via-zinc-950 to-black"></div>
    )}
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_40%,rgba(37,99,235,0.06),transparent)]"></div>

    <!-- Content — centered with CTAs visible -->
    <div class="relative z-10 w-full max-w-[1600px] mx-auto px-5 sm:px-8 lg:px-10 text-center flex flex-col items-center justify-center flex-1">

      <p class="text-blue-500 text-[10px] sm:text-xs font-bold uppercase tracking-[4px] mb-4 sm:mb-6">BGW California</p>
      <h1 class="text-white text-4xl sm:text-5xl md:text-6xl lg:text-8xl xl:text-9xl font-bold uppercase tracking-tight leading-none mb-4 sm:mb-6 drop-shadow-[0_4px_30px_rgba(0,0,0,0.5)]">
        {name}
      </h1>
      <p class="text-zinc-400 text-[10px] sm:text-xs uppercase tracking-[3px] sm:tracking-[4px] mb-6 sm:mb-8">{tagline}</p>

      <!-- Brief summary -->
      <p class="text-zinc-400 text-sm sm:text-base max-w-[600px] leading-relaxed mb-8 sm:mb-10">
        {briefSummary}
      </p>

      <!-- CTAs — prominent, inside the hero -->
      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
        <a
          href="/contact"
          class="text-center bg-blue-600 hover:bg-blue-700 text-white px-8 sm:px-10 py-3.5 sm:py-4 text-xs sm:text-sm font-bold uppercase tracking-[1px] no-underline rounded-none transition-colors duration-300"
        >Get a Quote</a>
        <a
          href={`/portfolio#${slug}`}
          class="text-center border border-white/20 text-white px-8 sm:px-10 py-3.5 sm:py-4 text-xs sm:text-sm font-bold uppercase tracking-[1px] no-underline rounded-none hover:bg-white/5 transition-colors duration-300 backdrop-blur-sm"
        >View Portfolio</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       SECTION 2 · HIGHLIGHTS
       ═══════════════════════════════════════════════════ -->
  <section class="bg-black py-16 sm:py-20 lg:py-28">
    <div class="w-full max-w-[1600px] mx-auto px-5 sm:px-8 lg:px-10">

      <div class="border-l-4 border-blue-600 pl-4 sm:pl-6 mb-10 sm:mb-16">
        <p class="text-zinc-500 text-[10px] sm:text-xs uppercase tracking-[3px] mb-2">Highlights</p>
        <h2 class="text-white text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold leading-tight">
          The highlights of {name}.
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-zinc-800">
        {highlights.map((item) => (
          <div class="group relative bg-zinc-950 overflow-hidden">
            <div class="aspect-[4/3] relative overflow-hidden">
              {item.image ? (
                <>
                  <img
                    src={item.image.src}
                    alt={item.title}
                    class="w-full h-full object-cover scale-110 group-hover:scale-[1.15] transition-transform duration-700"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/20 to-transparent"></div>
                </>
              ) : (
                <div class="w-full h-full bg-gradient-to-br from-zinc-800 to-zinc-950 group-hover:from-zinc-700 transition-all duration-500 flex items-center justify-center">
                  <span class="text-zinc-700 text-xs uppercase tracking-[2px]">Photo</span>
                </div>
              )}
            </div>
            <div class="p-5 sm:p-6">
              <h3 class="text-white text-base sm:text-lg font-bold mb-2">{item.title}</h3>
              <p class="text-zinc-400 text-sm leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       SECTION 3 · OVERVIEW — side-by-side
       Image left (rounded-sm) + Text & CTA right
       ═══════════════════════════════════════════════════ -->
  <section class="bg-zinc-950 py-16 sm:py-20 lg:py-28">
    <div class="w-full max-w-[1600px] mx-auto px-5 sm:px-8 lg:px-10">

      <div class="flex flex-col lg:flex-row gap-8 lg:gap-16 items-center">
        <!-- Left: Image -->
        <div class="w-full lg:w-1/2 relative overflow-hidden rounded-sm aspect-[4/3] border border-white/5">
          {showcaseImage ? (
            <>
              <img
                src={showcaseImage.src}
                alt={`${name} overview — BGW California`}
                class="absolute inset-0 w-full h-full object-cover scale-110"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-zinc-950/30 via-transparent to-transparent"></div>
            </>
          ) : (
            <div class="absolute inset-0 bg-gradient-to-br from-zinc-800/40 to-zinc-950 flex items-center justify-center">
              <span class="text-zinc-700 text-xs uppercase tracking-[3px]">Showcase Image</span>
            </div>
          )}
        </div>

        <!-- Right: Content -->
        <div class="w-full lg:w-1/2 flex flex-col justify-center">
          <div class="border-l-4 border-blue-600 pl-4 sm:pl-6 mb-6 sm:mb-8">
            <p class="text-zinc-500 text-[10px] sm:text-xs uppercase tracking-[3px] mb-2">Overview</p>
            <h2 class="text-white text-2xl sm:text-3xl md:text-4xl font-bold leading-tight">
              {headline}
            </h2>
          </div>

          <p class="text-zinc-400 text-sm sm:text-base leading-relaxed mb-8 sm:mb-10">
            {description}
          </p>

          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href="/contact"
              class="text-center bg-blue-600 hover:bg-blue-700 text-white px-8 py-3.5 text-xs font-bold uppercase tracking-[1px] no-underline rounded-none transition-colors duration-300"
            >Get a Quote</a>
            <a
              href={`/portfolio#${slug}`}
              class="text-center border border-white/20 text-white px-8 py-3.5 text-xs font-bold uppercase tracking-[1px] no-underline rounded-none hover:bg-white/5 transition-colors duration-300"
            >View Portfolio</a>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       SECTION 4 · TECHNICAL DATA (with icons)
       ═══════════════════════════════════════════════════ -->
  <section class="bg-black py-16 sm:py-20 lg:py-28">
    <div class="w-full max-w-[1600px] mx-auto px-5 sm:px-8 lg:px-10">

      <div class="border-l-4 border-blue-600 pl-4 sm:pl-6 mb-10 sm:mb-16">
        <p class="text-zinc-500 text-[10px] sm:text-xs uppercase tracking-[3px] mb-2">Technical Data</p>
        <h2 class="text-white text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold leading-tight">
          The technical details.
        </h2>
      </div>

      <div class="max-w-[900px] mx-auto">
        {specs.map((spec, i) => (
          <div class={`flex items-center gap-4 py-4 sm:py-5 px-4 sm:px-6 ${i % 2 === 0 ? 'bg-zinc-950' : 'bg-zinc-900/50'} ${i === 0 ? 'border-t border-white/5' : ''}`}>
            <!-- Icon -->
            <div class="flex-shrink-0 w-9 h-9 sm:w-10 sm:h-10 flex items-center justify-center rounded-none bg-blue-600/10 border border-blue-600/20">
              {spec.icon && iconMap[spec.icon] ? (
                <svg class="w-4 h-4 sm:w-5 sm:h-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  {iconMap[spec.icon].split(' M').map((d, idx) => (
                    <path stroke-linecap="round" stroke-linejoin="round" d={idx === 0 ? d : `M${d}`} />
                  ))}
                </svg>
              ) : (
                <svg class="w-4 h-4 sm:w-5 sm:h-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
              )}
            </div>
            <!-- Label + value -->
            <div class="flex flex-1 flex-col sm:flex-row sm:items-center sm:justify-between gap-0.5 sm:gap-4 min-w-0">
              <span class="text-zinc-400 text-xs sm:text-sm font-bold truncate">{spec.label}</span>
              <span class="text-white text-xs sm:text-sm font-bold sm:text-right">{spec.value}</span>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       SECTION 5 · ACTION CARDS
       ═══════════════════════════════════════════════════ -->
  <section class="bg-zinc-950 py-12 sm:py-16 lg:py-20">
    <div class="w-full max-w-[1600px] mx-auto px-5 sm:px-8 lg:px-10">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-px bg-zinc-800">

        <a href="/contact" class="group bg-black hover:bg-zinc-900 transition-colors duration-300 p-6 sm:p-8 lg:p-10 flex flex-row sm:flex-col items-center sm:text-center gap-4 sm:gap-0 no-underline">
          <svg class="w-8 h-8 sm:w-10 sm:h-10 text-zinc-600 group-hover:text-blue-600 transition-colors duration-300 flex-shrink-0 sm:mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z" />
          </svg>
          <span class="text-white text-xs sm:text-sm font-bold uppercase tracking-[1px]">Request a Quote</span>
        </a>

        <a href={`/portfolio#${slug}`} class="group bg-black hover:bg-zinc-900 transition-colors duration-300 p-6 sm:p-8 lg:p-10 flex flex-row sm:flex-col items-center sm:text-center gap-4 sm:gap-0 no-underline">
          <svg class="w-8 h-8 sm:w-10 sm:h-10 text-zinc-600 group-hover:text-blue-600 transition-colors duration-300 flex-shrink-0 sm:mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
          </svg>
          <span class="text-white text-xs sm:text-sm font-bold uppercase tracking-[1px]">View Portfolio</span>
        </a>

        <a href="/contact" class="group bg-black hover:bg-zinc-900 transition-colors duration-300 p-6 sm:p-8 lg:p-10 flex flex-row sm:flex-col items-center sm:text-center gap-4 sm:gap-0 no-underline">
          <svg class="w-8 h-8 sm:w-10 sm:h-10 text-zinc-600 group-hover:text-blue-600 transition-colors duration-300 flex-shrink-0 sm:mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
          </svg>
          <span class="text-white text-xs sm:text-sm font-bold uppercase tracking-[1px]">Contact Us</span>
        </a>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       SECTION 6 · OTHER SERVICES
       ═══════════════════════════════════════════════════ -->
  <section class="bg-black py-16 sm:py-20 lg:py-28 border-t border-white/5">
    <div class="w-full max-w-[1600px] mx-auto px-5 sm:px-8 lg:px-10">

      <div class="border-l-4 border-blue-600 pl-4 sm:pl-6 mb-10 sm:mb-16">
        <p class="text-zinc-500 text-[10px] sm:text-xs uppercase tracking-[3px] mb-2">Explore</p>
        <h2 class="text-white text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold leading-tight">
          Discover our other services.
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-zinc-800">
        {siblings.map((svc) => (
          <a
            href={`/services/${svc.slug}`}
            class="group bg-zinc-950 hover:bg-zinc-900 transition-colors duration-300 no-underline"
          >
            <div class="aspect-[16/10] relative overflow-hidden">
              {svc.image ? (
                <>
                  <img
                    src={svc.image.src}
                    alt={svc.title}
                    class="w-full h-full object-cover scale-110 group-hover:scale-[1.15] transition-transform duration-700"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-zinc-950/60 via-transparent to-transparent"></div>
                </>
              ) : (
                <div class="w-full h-full bg-gradient-to-br from-zinc-800 to-zinc-950 group-hover:from-zinc-700 transition-all duration-500 flex items-center justify-center">
                  <span class="text-zinc-700 text-xs uppercase tracking-[2px]">Photo</span>
                </div>
              )}
            </div>
            <div class="p-5 sm:p-6 lg:p-8">
              <h3 class="text-white text-lg sm:text-xl font-bold uppercase tracking-wide mb-2">{svc.title}</h3>
              <p class="text-zinc-500 text-[10px] sm:text-xs uppercase tracking-[2px]">{svc.tagline}</p>
              <span class="inline-block mt-3 sm:mt-4 text-blue-600 text-[10px] sm:text-xs font-bold uppercase tracking-[2px] border-b border-blue-600/30 pb-0.5 group-hover:border-blue-600 transition-colors duration-300">
                Learn More →
              </span>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

  <Footer />
</Layout>
